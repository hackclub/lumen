---
import GuideHeroVideo from '../guides/GuideHeroVideo.svelte';
import LumenLogo from '../LumenLogo.astro';
import BobbingText from '../BobbingText.astro';
import Button from '../Button.svelte';
import { getCollection } from 'astro:content';
import { extractGuideDescription } from '../../utils/seo';

const route = Astro.locals.starlightRoute;
const title = route.entry.data.title;
const subtitle = route.entry.data.subtitle?.trim();
const summary =
  extractGuideDescription(route.entry.body, route.entry.data.description, 1) ??
  route.entry.data.description ??
  'Follow this chapter to keep building your Minecraft shaderpack.';
const heroSummary =
  route.entry.data.hero?.tagline ??
  route.entry.data.description ??
  summary;
const pathParts = route.id.split('/');
const currentSlug = pathParts.at(-1) ?? route.id;
const directory = currentSlug === 'guides' ? 'guides' : pathParts.slice(0, -1).join('/');
const isSeriesPage = route.id === directory || /^\d{2}-/.test(currentSlug);
const showHero = route.id === 'guides/01-getting-oriented';
const heroLines = showHero ? [subtitle, heroSummary].filter(Boolean).slice(0, 2) : [];

const siblingEntries = isSeriesPage
  ? (await getCollection('docs', ({ id, data }) => {
      if (data.draft) return false;
      if (!id.startsWith(`${directory}/`) || id === `${directory}/index`) return false;

      const baseName = id.split('/').at(-1) ?? '';
      return /^\d{2}-/.test(baseName);
    })).sort((a, b) => {
      const leftOrder = a.data.sidebar.order ?? Number.MAX_VALUE;
      const rightOrder = b.data.sidebar.order ?? Number.MAX_VALUE;
      if (leftOrder !== rightOrder) return leftOrder - rightOrder;
      return a.id.localeCompare(b.id);
    })
  : [];

const chapterItems = siblingEntries.map((entry, index) => ({
  href: `/${entry.id}`,
  title: entry.data.title,
  number: String(index + 1).padStart(2, '0'),
  current: entry.id === route.id
}));
---

<section class:list={['guide-page-title', { 'guide-page-title--compact': !showHero }]}>
  {
    showHero && (
      <div class="guide-page-title__hero">
        <GuideHeroVideo client:load />
        <div class="guide-page-title__hero-copy">
          <LumenLogo variant="guide" showHackclubBadge />
          <div class="guide-page-title__hero-lines">
            {heroLines.map((line) => <BobbingText text={line} variant="guide" />)}
          </div>
          <Button client:load href="https://submit.hackclub.com/hackcraft-lumen">
            Submit your shader
          </Button>
        </div>
      </div>
    )
  }

  <div class="guide-page-title__intro">
    {
      chapterItems.length > 0 && (
        <nav class="guide-page-title__chapters" aria-label="Guide chapters">
          {chapterItems.map((item) => (
            <a
              href={item.href}
              class:list={['guide-page-title__chapter', { 'guide-page-title__chapter--current': item.current }]}
              aria-current={item.current ? 'page' : undefined}
            >
              <span class="guide-page-title__chapter-number">
                Ch.{item.number}
              </span>
              <span class="guide-page-title__chapter-name">{item.title}</span>
            </a>
          ))}
        </nav>
      )
    }
  </div>
</section>

<style>
  .guide-page-title {
    display: grid;
    grid-template-rows: minmax(24rem, 62svh) auto;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(12, 9, 16, 0.82), rgba(12, 9, 16, 0.98)),
      rgba(12, 9, 16, 0.96);
    border-radius: 0 0 1.6rem 1.6rem;
    overflow: clip;
  }

  .guide-page-title__hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 3vw, 2.75rem);
  }

  .guide-page-title__hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.15rem;
    width: 100%;
    align-content: center;
    justify-items: center;
    text-align: center;
  }

  .guide-page-title__hero-lines {
    display: grid;
    gap: 0.35rem;
    justify-items: center;
  }

  .guide-page-title__kicker {
    margin: 0;
    color: rgba(255, 208, 188, 0.84);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .guide-page-title__intro {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
    margin-inline: clamp(1rem, 3vw, 2rem);
    margin-bottom: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.5rem, 3vw, 2.75rem);
    padding-inline: clamp(2rem, 6vw, 5rem);
    border-radius: 1.35rem;
    background:
      linear-gradient(180deg, rgba(12, 9, 16, 0.82), rgba(12, 9, 16, 0.98)),
      rgba(12, 9, 16, 0.96);
  }

  .guide-page-title--compact {
    grid-template-rows: auto;
  }

  .guide-page-title__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .guide-page-title__chapters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.9rem;
    width: 100%;
  }

  .guide-page-title__chapter {
    display: grid;
    gap: 0.4rem;
    min-height: 7.5rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
      rgba(255, 255, 255, 0.015);
    color: inherit;
    text-decoration: none;
    transition: transform 160ms ease, border-color 160ms ease, background-color 160ms ease;
  }

  .guide-page-title__chapter:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 208, 188, 0.32);
    background-color: rgba(255, 255, 255, 0.045);
  }

  .guide-page-title__chapter--current {
    border-color: rgba(255, 208, 188, 0.36);
    background:
      linear-gradient(180deg, rgba(233, 91, 95, 0.14), rgba(255, 255, 255, 0.03)),
      rgba(255, 255, 255, 0.03);
  }

  .guide-page-title__chapter-number {
    color: rgba(255, 208, 188, 0.76);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .guide-page-title__chapter-name {
    color: #fff7ef;
    font-family: var(--guide-serif);
    font-size: 1.35rem;
    line-height: 1.05;
    text-wrap: balance;
  }

  @media (max-width: 40rem) {
    .guide-page-title {
      grid-template-rows: minmax(22rem, 58svh) auto;
      border-radius: 0 0 1rem 1rem;
    }

    .guide-page-title__hero {
      min-height: 50svh;
    }

    .guide-page-title__chapters {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 93.75rem) {
    .guide-page-title__intro {
      padding-inline: clamp(1.75rem, 3vw, 3.5rem);
    }
  }
</style>
