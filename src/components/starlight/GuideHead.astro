---
import { buildCanonicalHref, extractGuideDescription, GUIDE_SITE_TITLE } from '../../utils/seo';

const route = Astro.locals.starlightRoute;
const description =
  extractGuideDescription(route.entry.body, route.entry.data.description, 3) ??
  'Step-by-step Minecraft shader guide for Hack Club Lumen.';
const canonicalHref = buildCanonicalHref(Astro.url.pathname, Astro.site);
const guideIndexHref = buildCanonicalHref('/guides', Astro.site);

const filteredHead = route.head.filter((entry) => {
  if (entry.tag === 'meta') {
    const name = entry.attrs?.name;
    const property = entry.attrs?.property;

    if (
      name === 'description' ||
      name === 'twitter:card' ||
      name === 'twitter:title' ||
      name === 'twitter:description' ||
      name === 'robots'
    ) {
      return false;
    }

    if (
      property === 'og:description' ||
      property === 'og:url' ||
      property === 'og:type' ||
      property === 'article:section' ||
      property === 'og:image' ||
      property === 'og:image:alt'
    ) {
      return false;
    }
  }

  if (entry.tag === 'link' && entry.attrs?.rel === 'canonical') return false;

  return true;
});

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: route.entry.data.title,
  description,
  url: canonicalHref,
  articleSection: GUIDE_SITE_TITLE,
  learningResourceType: 'Tutorial',
  inLanguage: route.lang,
  isPartOf: {
    '@type': 'CreativeWorkSeries',
    name: GUIDE_SITE_TITLE,
    url: guideIndexHref
  },
  publisher: {
    '@type': 'Organization',
    name: 'Hack Club',
    url: 'https://hackclub.com'
  },
  ...(route.lastUpdated ? { dateModified: route.lastUpdated.toISOString() } : {})
};
---

{filteredHead.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

<link rel="canonical" href={canonicalHref} />
<meta name="description" content={description} />
<meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
<meta property="og:type" content="article" />
<meta property="og:url" content={canonicalHref} />
<meta property="og:description" content={description} />
<meta property="article:section" content={GUIDE_SITE_TITLE} />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={route.entry.data.title} />
<meta name="twitter:description" content={description} />
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
