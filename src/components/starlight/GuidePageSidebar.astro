---
import GuideTocList from './GuideTocList.astro';

const toc = Astro.locals.starlightRoute.toc;
const chapterItems = toc?.items?.filter((item) => item.slug !== '_top') ?? [];
---

{
  toc && (
    <>
      <div class="guide-page-sidebar sl-hidden lg:sl-block">
        <div class="guide-page-sidebar__panel">
          <p class="guide-page-sidebar__eyebrow">Guide Outline</p>
          <h2 id="guide-page-sidebar-title">Chapter ToC</h2>
          <nav aria-labelledby="guide-page-sidebar-title">
            <GuideTocList items={chapterItems} />
          </nav>
        </div>
      </div>
    </>
  )
}

<style>
  .guide-page-sidebar {
    padding: 1.5rem var(--sl-sidebar-pad-x);
  }

  .guide-page-sidebar__panel {
    width: calc(var(--sl-sidebar-width) - 2 * var(--sl-sidebar-pad-x));
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      rgba(18, 13, 21, 0.7);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.24);
  }

  .guide-page-sidebar__eyebrow {
    margin: 0 0 0.4rem;
    color: rgba(255, 208, 188, 0.8);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .guide-page-sidebar h2 {
    margin: 0 0 0.8rem;
    color: #fff6eb;
    font-family: var(--guide-serif);
    font-size: 1.5rem;
    line-height: 1.1;
  }

  @media (min-width: 72rem) {
    .guide-page-sidebar__panel {
      max-width: calc(
        (
          (
              100vw - var(--sl-sidebar-width) - 2 * var(--sl-content-pad-x) - 2 *
                var(--sl-sidebar-pad-x)
            ) * 0.25
        )
      );
    }
  }
</style>
