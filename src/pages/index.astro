---
import "../styles/global.css";
import ScrollVideo from "../components/ScrollVideo.svelte";

const titleText = "Make Minecraft shaders, get Minecraft and GPUs!";
const titleChars = titleText.split("");
---

<ScrollVideo client:only="svelte" />

<main class="relative">
  <section class="flex h-screen items-center justify-center">
    <div class="max-w-2xl text-center text-white">
      <div class="flex items-end justify-center cursor-pointer">
        {
          [1, 2, 3, 4, 5].map((i) => (
            <span
              class={`logo-letter-wrap ${i === 1 ? "relative" : ""}`}
              style={`--i: ${i - 1}`}
            >
              <img src={`/img/letter${i}.png`} alt="" class="logo-letter" draggable="false" />

              {i === 1 && (
                <a href="https://hackclub.com" target="_blank">
                  <img
                    draggable="false"
                    src="/img/hackclub.png"
                    alt="Hack Club"
                    class="hackclub-badge"
                  />
                </a>
              )}
            </span>
          ))
        }
      </div>

      <div class="hero-title-wrap">
        {titleChars.map((char, i) => (
          <span
            class="title-letter-wrap"
            style={`--i: ${i}`}
          >
            <span
              class="title-letter"
              data-text={char}
              style={`--i: ${i}; --total: ${titleChars.length}`}
            >{char}</span>
          </span>
        ))}
      </div>

      <div class="mt-8 flex justify-center">
        <button class="group inline-block relative border-none bg-none p-0 cursor-pointer font-[Minecraftia,monospace] text-2xl text-white [text-shadow:3px_3px_0_#1F102B] [image-rendering:pixelated]">
          <img src="/img/button-normal.png" alt="" class="block [zoom:3] [image-rendering:pixelated] group-hover:hidden group-active:hidden" draggable="false" />
          <img src="/img/button-hover.png" alt="" class="hidden [zoom:3] [image-rendering:pixelated] group-hover:block group-active:hidden" draggable="false" />
          <img src="/img/button-pressed.png" alt="" class="hidden [zoom:3] [image-rendering:pixelated] group-active:block" draggable="false" />
          <span class="absolute inset-0 flex items-center justify-center pointer-events-none [text-shadow:3px_3px_0_#1F102B] translate-y-1.5">Submit your shader</span>
        </button>
      </div>
    </div>
  </section>

  <section class="flex h-screen items-center justify-center">
    <div class="max-w-2xl text-center text-white">
      <h2 class="section-title" data-text="What is Lumen?">What is Lumen?</h2>
      <p class="section-body mt-6 text-lg leading-relaxed text-white/70">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
      </p>
      <p class="section-body mt-4 text-lg leading-relaxed text-white/70">
        Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.
      </p>
    </div>
  </section>

  <section class="flex h-screen items-center justify-center">
    <div class="max-w-2xl text-center text-white">
      <h2 class="section-title" data-text="Prizes">Prizes</h2>
      <p class="section-body mt-6 text-lg leading-relaxed text-white/70">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae. Proin vel ante a orci tempus eleifend ut et magna.
      </p>
      <p class="section-body mt-4 text-lg leading-relaxed text-white/70">
        Nulla facilisi. Maecenas sodales nec purus eget posuere. Sed sapien quam, pretium a risus in, porttitor dapibus erat.
      </p>
    </div>
  </section>

  <section class="flex h-screen items-center justify-center">
    <div class="max-w-2xl text-center text-white">
      <h2 class="section-title" data-text="How It Works">How It Works</h2>
      <p class="section-body mt-6 text-lg leading-relaxed text-white/70">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Fusce dapibus, tellus ac cursus commodo, tortor mauris condimentum nibh, ut fermentum massa justo sit amet risus.
      </p>
      <p class="section-body mt-4 text-lg leading-relaxed text-white/70">
        Cras mattis consectetur purus sit amet fermentum. Donec id elit non mi porta gravida at eget metus. Aenean lacinia bibendum nulla sed consectetur.
      </p>
    </div>
  </section>

  <section class="flex h-screen items-center justify-center">
    <div class="max-w-2xl text-center text-white">
      <h2 class="section-title" data-text="FAQ">FAQ</h2>
      <p class="section-body mt-6 text-lg leading-relaxed text-white/70">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus posuere velit aliquet. Praesent commodo cursus magna, vel scelerisque nisl consectetur et.
      </p>
      <p class="section-body mt-4 text-lg leading-relaxed text-white/70">
        Vivamus sagittis lacus vel augue laoreet rutrum faucibus dolor auctor. Nullam quis risus eget urna mollis ornare vel eu leo.
      </p>
    </div>
  </section>
</main>

<script>
  const wraps = document.querySelectorAll<HTMLElement>(".logo-letter-wrap");
  const letters = document.querySelectorAll<HTMLElement>(".logo-letter");
  const badge = document.querySelector<HTMLElement>(".hackclub-badge");
  const titleWraps = document.querySelectorAll<HTMLElement>(".title-letter-wrap");
  const titleLetters = document.querySelectorAll<HTMLElement>(".title-letter");

  window.addEventListener("load", () => {
    wraps.forEach((el) => {
      el.style.animationPlayState = "running";
    });
    letters.forEach((el) => {
      el.style.animationPlayState = "running";
    });
    if (badge) badge.style.animationPlayState = "running";
    titleWraps.forEach((el) => {
      el.style.animationPlayState = "running";
    });
    titleLetters.forEach((el) => {
      el.style.animationPlayState = "running";
    });
  });

  letters.forEach((el) => {
    el.addEventListener("click", () => {
      el.style.animation = "none";
      el.offsetHeight;
      el.style.animation = "logo-pop-click 0.3s steps(6) forwards";
    });
  });

  titleLetters.forEach((el) => {
    el.addEventListener("click", () => {
      el.style.animation = "none";
      el.offsetHeight;
      el.style.animation = "logo-pop-click 0.3s steps(6) forwards";
    });
  });
</script>
