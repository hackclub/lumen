---
import "../styles/global.css";
---

<main class="relative min-h-screen flex items-center justify-center" style="background-image: url('/img/blackstone.png'); background-size: 128px 128px; image-rendering: pixelated;">
  <section class="flex h-screen items-center justify-center">
    <div class="max-w-4xl text-center text-white">
      <h1 class="section-title" data-text="Coming Soon...">Coming Soon...</h1>
      <p class="leading-relaxed text-[#E95B5F] text-2xl minecraft-text mt-6">
        We're working hard to get guides out for you ASAP! For now, please check out
        <a href="https://shaderlabs.org/wiki/Getting_Started" class="text-blue-400 hover:text-blue-300 transition-colors">ShaderLabs</a>!
      </p>
    </div>
  </section>
</main>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }
</style>
